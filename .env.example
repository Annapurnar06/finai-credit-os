# FINAI Credit OS — Environment Configuration
# Copy to .env and fill in your values

# Database
DATABASE_URL=YOUR_DATABASE_URL_HERE
DATABASE_URL_SYNC=YOUR_DATABASE_URL_SYNC_HERE

# Redis
REDIS_URL=redis://localhost:6379/0

# LLM Providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Observability
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Memory (Mem0)
MEM0_API_KEY=

# Voice (M3+)
CARTESIA_API_KEY=
DEEPGRAM_API_KEY=

# Environment
ENVIRONMENT=development
LOG_LEVEL=INFO
